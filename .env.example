# Python Automation API - Environment Configuration
# Copia este archivo a .env y configura los valores

# Oracle Database
ORACLE_USER=system
ORACLE_PASSWORD=your_password_here
ORACLE_DSN=localhost:1521/orclpdb1

# Server
HOST=0.0.0.0
PORT=8000

# CORS (separados por coma, o "*" para permitir todos)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
